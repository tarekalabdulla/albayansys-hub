# ============================================================
# قالب متغيرات البيئة للـ backend
# انسخه إلى /var/www/hulul/backend/.env واملأ القيم من /root/hulul-credentials.txt
# ============================================================

# منفذ التشغيل (Nginx يعكس عليه)
PORT=4000
NODE_ENV=production

# قاعدة البيانات (من /root/hulul-credentials.txt)
DATABASE_URL=postgres://hulul_app:CHANGE_ME@127.0.0.1:5432/hulul

# مفتاح JWT (من /root/hulul-credentials.txt)
JWT_SECRET=CHANGE_ME_RANDOM_HEX_96_CHARS
JWT_EXPIRES_IN=7d

# مفتاح تشفير أسرار السنترال في القاعدة
ENCRYPTION_KEY=CHANGE_ME_RANDOM_HEX_64_CHARS

# دومينات مسموحة للـ CORS (افصل بفواصل)
CORS_ORIGIN=https://app.yourdomain.com

# تفعيل المحاكي للأحداث (اتركه false في الإنتاج)
ENABLE_SIMULATOR=false

# (اختياري) إعدادات Yeastar — تُضاف عبر واجهة الإعدادات وليس هنا
# YEASTAR_HOST=
# YEASTAR_PORT=
# YEASTAR_API_USER=
# YEASTAR_API_SECRET=
