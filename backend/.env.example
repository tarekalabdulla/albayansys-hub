# انسخ هذا الملف إلى .env واملأ القيم
NODE_ENV=production
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://hulul_user:CHANGE_ME@localhost:5432/hulul_db

# JWT — أنشئ secret عشوائي قوي:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# CORS — دومين الفرونت (Lovable preview أو مخصص)
CORS_ORIGIN=https://id-preview--9f29d651-62b2-4e2a-bde1-f120ee6f3842.lovable.app,https://hulul-albayan.com

# bcrypt salt rounds
BCRYPT_ROUNDS=12

# مفتاح تشفير أسرار السنترال (Yeastar) — 64 حرف hex (32 بايت)
# أنشئه عشوائياً:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_TO_64_HEX_CHARS

# اسمح بشهادات TLS موقّعة ذاتياً (PBX المحلي عادة self-signed)
# اضبطها على 0 لاختبار اتصال Yeastar فقط لو واجهت SELF_SIGNED_CERT_IN_CHAIN
NODE_TLS_REJECT_UNAUTHORIZED=0
