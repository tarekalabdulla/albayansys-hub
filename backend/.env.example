# انسخ هذا الملف إلى .env واملأ القيم
NODE_ENV=production
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://hulul_user:CHANGE_ME@localhost:5432/hulul_db

# JWT — أنشئ secret عشوائي قوي:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# CORS — دومين الفرونت (Lovable preview أو مخصص)
CORS_ORIGIN=https://id-preview--9f29d651-62b2-4e2a-bde1-f120ee6f3842.lovable.app,https://hulul-albayan.com

# bcrypt salt rounds
BCRYPT_ROUNDS=12

# المحاكي — true لتوليد بيانات حيّة وهمية (للتجربة فقط)
# في الإنتاج: اتركه false حتى لا يُعيد ملء قاعدة البيانات بعد reset_data.sql
SIMULATOR_ENABLED=false

# ============================================================
# Yeastar P-Series Webhook (استقبال أحداث المكالمات الحقيقية)
# ------------------------------------------------------------
# 1) في PBX: Settings → Event Center → Webhook
#    URL:    https://api.hulul-albayan.com/api/webhooks/yeastar
#    Method: POST
#    أحداث: ExtensionRing, ExtensionAnswer, ExtensionHangup, ExtensionStatus
#
# 2) أنشئ السرّ:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    والصقه في PBX (HMAC Secret) وهنا.
# ============================================================
YEASTAR_WEBHOOK_SECRET=CHANGE_ME_RANDOM_HEX
# قائمة IPs مسموح بها (افصل بفاصلة). اتركها فارغة لتعطيل الفحص.
YEASTAR_ALLOWED_IPS=

# ============================================================
# Yeastar Open API (المرحلة 2 — اتصال نشِط بدلاً من webhook)
# ------------------------------------------------------------
# يُفعَّل تلقائياً عند ضبط الثلاثة المتغيّرات أدناه. اتركها فارغة لتعطيل.
# في PBX: System → API → فعّل Open API → أنشئ مستخدم API.
#
# YEASTAR_API_BASE: عنوان PBX كاملاً مع البورت (HTTPS مُوصى به)
# YEASTAR_API_TOPICS: أرقام الأحداث المشترَك بها (افتراضي: مكالمات+امتدادات)
#   30012 = CallStatus, 30013 = ExtensionStatus, 30014 = QueueMember
# ============================================================
YEASTAR_API_BASE=
YEASTAR_API_USER=
YEASTAR_API_PASS=
YEASTAR_API_TOPICS=30012,30013,30014

# ============================================================
# Yeastar Integration v2 (Production-Grade — migration_007)
# ------------------------------------------------------------
# OAuth credentials (يُفضَّل عن username/password للأمان)
# تُستخدم بواسطة services/yeastarService.js و realtime/yeastar-openapi.js
YEASTAR_BASE_URL=
YEASTAR_CLIENT_ID=
YEASTAR_CLIENT_SECRET=

# Webhook v2: POST /api/yeastar/webhook/call-event/:token
# يتحقّق من TOKEN في URL + HMAC اختياري (X-Yeastar-Signature)
# أنشئ token عشوائي طويل:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
YEASTAR_WEBHOOK_TOKEN=

# ============================================================
# AMI (Asterisk Manager Interface) — اختياري، live monitoring إضافي
# ------------------------------------------------------------
# يبدأ تلقائياً فقط إذا ضُبطت الأربعة. اتركها فارغة للتعطيل (الافتراضي).
# في PBX: Settings → System → Security → AMI → Enable + أنشئ مستخدم.
# ⚠️ لن يعمل إذا PBX خلف Yeastar Cloud RAS (لا منفذ TCP مكشوف).
# ============================================================
YEASTAR_AMI_HOST=
YEASTAR_AMI_PORT=5038
YEASTAR_AMI_USERNAME=
YEASTAR_AMI_PASSWORD=
